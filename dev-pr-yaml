trigger: none

pr:
  branches:
    include:
      - release/*
      - master
      - staging

resources:
  repositories:
    - repository: ai_code_review, 
      type: git
      name: <ProjectName>/ai_code_review, 

pool:
  vmImage: 'windows-latest'

variables:
  NODE_VERSION: '20.x'

steps:

# ==============================
# Checkout Main Repository
# ==============================
- checkout: self
  clean: true
  fetchDepth: 0
  persistCredentials: true

# ==============================
# Checkout AI Platform Repository
# ==============================
- checkout: ai_code_review, 
  clean: true
  fetchDepth: 0
  persistCredentials: true

# ==============================
# Transform AI Settings JSON
# ==============================
- task: FileTransform@2
  displayName: 'Transform AISettings.json'
  inputs:
    folderPath: '$(Build.SourcesDirectory)/ai_code_review'
    enableXmlTransform: false
    jsonTargetFiles: 'AISettings.json'

# ==============================
# Transform Execution Settings JSON
# ==============================
- task: FileTransform@2
  displayName: 'Transform ExecutionSettings.json'
  inputs:
    folderPath: '$(Build.SourcesDirectory)/ai_code_review'
    enableXmlTransform: false
    jsonTargetFiles: 'ExecutionSettings.json'

# ==============================
# Install Node.js
# ==============================
- task: UseNode@1
  displayName: 'Install Node.js'
  inputs:
    version: '20.x'

# ==============================
# Debug Folder Structure
# ==============================
- powershell: |

    Write-Host "===================================="
    Write-Host "BUILD SOURCES DIRECTORY"
    Write-Host "===================================="

    dir "$(Build.SourcesDirectory)"

  displayName: 'Debug Source Directory'

# ==============================
# Extract PR Diff
# ==============================
- powershell: |

    $targetBranch = "$(System.PullRequest.TargetBranch)" -replace "refs/heads/", ""

    git fetch origin $targetBranch

    $diffPath = "$(Build.SourcesDirectory)/pr_diff.txt"

    # PowerShell captures git stdout as a string[] (one per line).
    # We MUST explicitly join with `n before writing, otherwise
    # WriteAllText / string-binding joins with $OFS (space) and produces
    # a single-line file that the diff parser sees as one file.
    $diffLines = @(git diff "origin/$targetBranch...HEAD" 2>&1)
    if ($LASTEXITCODE -ne 0) {
        throw "git diff failed (exit $LASTEXITCODE): $($diffLines -join ' ')"
    }

    $diff = [string]::Join("`n", $diffLines).Trim()
    if ([string]::IsNullOrWhiteSpace($diff)) {
        Write-Host "No differences found between PR branch and target branch."
        Write-Host "##vso[task.setvariable variable=SkipAIReview]true"
        New-Item -ItemType File -Path $diffPath -Force | Out-Null
        exit 0
    }

    if (-not ($diff -match '(?m)^diff --git ')) {
        throw "git diff output is not a unified diff (expected lines starting with 'diff --git'). Check that git stdout was joined with newlines."
    }

    $utf8NoBom = New-Object System.Text.UTF8Encoding $false
    [System.IO.File]::WriteAllText($diffPath, $diff, $utf8NoBom)

    $lineCount = ($diff -split "`r?`n").Count
    $fileCount = ([regex]::Matches($diff, '(?m)^diff --git ')).Count
    Write-Host "Wrote pr_diff.txt ($lineCount lines, $fileCount files, $((Get-Item $diffPath).Length) bytes)"

  workingDirectory: '$(Build.SourcesDirectory)/$(Build.Repository.Name)'
  displayName: 'Extract PR Diff'
  
# ==============================
# Run AI Review
# ==============================
- powershell: |

    Write-Host "===================================="
    Write-Host "CHANGING DIRECTORY"
    Write-Host "===================================="

    cd "$(Build.SourcesDirectory)/ai_code_review"

    Write-Host "Current Directory:"
    Get-Location

    Write-Host "===================================="
    Write-Host "INSTALLING DEPENDENCIES"
    Write-Host "===================================="

    npm ci

    Write-Host "===================================="
    Write-Host "RUNNING AI REVIEW"
    Write-Host "===================================="

    npx ts-node scripts/review-dev-pr.ts

  displayName: 'Run AI Review'
  condition: and(succeeded(), ne(variables['AI_CODE_PILOT_SKIP'], 'true'))
  env:
    BUILD_SOURCESDIRECTORY: $(Build.SourcesDirectory)
    SYSTEM_ACCESSTOKEN: $(System.AccessToken)
